generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Modpack {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name              String   @db.VarChar(191)
  slug              String   @unique @db.VarChar(191)
  description       String?  @db.Text
  icon              String?  @db.VarChar(191)
  source            String   @default("modrinth") @db.VarChar(191)
  source_id         String?  @db.VarChar(191)
  minecraft_version String   @db.VarChar(191)
  modloader         String   @db.VarChar(191)
  is_active         Int      @default(1) @db.TinyInt
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)

  versions ModpackVersion[]
  servers  ServerModpack[]

  @@map("modpacks")
}

model ModpackVersion {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  modpack_id     BigInt   @db.UnsignedBigInt
  version        String   @db.VarChar(191)
  download_url   String   @db.VarChar(191)
  file_size      BigInt?  @db.BigInt
  checksum       String?  @db.VarChar(191)
  is_recommended Int      @default(0) @db.TinyInt
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  modpack Modpack        @relation(fields: [modpack_id], references: [id])
  servers ServerModpack[]

  @@map("modpack_versions")
}

model ServerModpack {
  id                 BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  server_id          String   @db.VarChar(36)
  modpack_id         BigInt   @db.UnsignedBigInt
  modpack_version_id BigInt   @db.UnsignedBigInt
  status             String   @default("pending") @db.VarChar(191)
  install_log        String?  @db.Text
  installed_at       DateTime? @db.Timestamp(0)
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)

  modpack Modpack        @relation(fields: [modpack_id], references: [id])
  version ModpackVersion @relation(fields: [modpack_version_id], references: [id])

  @@unique([server_id])
  @@map("server_modpacks")
}

model ModpackSettings {
  id         String   @id @default(uuid())
  key        String   @unique @db.VarChar(255)
  value      String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt @db.Timestamp(0)

  @@map("modpack_settings")
}
